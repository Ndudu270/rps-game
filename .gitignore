```gitignore
# Compiled and build artifacts
*.js
*.tsbuildinfo
dist/
build/
*.o
*.obj

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
.env.*

# Editors
.vscode/
.idea/

# Coverage
coverage/
htmlcov/
*.coverage

# TypeScript specific
*.d.ts
*.map
```
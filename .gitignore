```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
target/

# Environment variables
.env
.env.local
*.env.*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
.venv/
.env
.env.local

# Coverage reports
coverage/
htmlcov/
.coverage

# Temporary files
*.tmp
*.temp
*.bak

# OS generated files
.DS_Store
Thumbs.db

# MyPy cache
.mypy_cache/
.pytest_cache/
```
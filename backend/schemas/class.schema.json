{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "baseStatModifiers",
    "derivedStatModifiers",
    "stanceAffinity",
    "startingWeaponTags",
    "startingArmorTags",
    "skillIds",
    "passives",
    "tags"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the class"
    },
    "name": {
      "type": "string",
      "description": "Display name"
    },
    "description": {
      "type": "string",
      "description": "Brief flavor or mechanical description"
    },
    "baseStatModifiers": {
      "type": "object",
      "required": ["strength", "agility", "intelligence", "charisma", "endurance", "perception", "luck"],
      "properties": {
        "strength": { "type": "number" },
        "agility": { "type": "number" },
        "intelligence": { "type": "number" },
        "charisma": { "type": "number" },
        "endurance": { "type": "number" },
        "perception": { "type": "number" },
        "luck": { "type": "number" }
      },
      "additionalProperties": false
    },
    "derivedStatModifiers": {
      "type": "object",
      "required": ["hp", "attack", "defense", "speed"],
      "properties": {
        "hp": { "type": "number" },
        "attack": { "type": "number" },
        "defense": { "type": "number" },
        "speed": { "type": "number" }
      },
      "additionalProperties": false
    },
    "stanceAffinity": {
      "type": "object",
      "required": ["aggressive", "balanced", "defensive"],
      "properties": {
        "aggressive": { "type": "number" },
        "balanced": { "type": "number" },
        "defensive": { "type": "number" }
      },
      "additionalProperties": false
    },
    "startingWeaponTags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "startingArmorTags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "skillIds": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "passives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "effect"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "effect": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
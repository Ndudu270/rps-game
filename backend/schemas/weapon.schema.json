{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "id",
    "name",
    "type",
    "category",
    "rarity",
    "damage",
    "scaling",
    "combatModifiers",
    "allowedClasses",
    "allowedRaces",
    "durability",
    "cost",
    "sellValue",
    "description",
    "tags"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique item identifier"
    },
    "name": {
      "type": "string",
      "description": "Display name"
    },
    "type": {
      "type": "string",
      "enum": ["weapon", "armor", "consumable", "material"],
      "description": "Item type category"
    },
    "category": {
      "type": "string",
      "description": "Specific subtype (e.g., sword, axe, heavy armor)"
    },
    "rarity": {
      "type": "string",
      "enum": ["common", "uncommon", "rare", "epic", "legendary"],
      "description": "Item rarity tier"
    },
    "damage": {
      "type": "object",
      "required": ["base", "min", "max"],
      "properties": {
        "base": { "type": "number" },
        "min": { "type": "number" },
        "max": { "type": "number" }
      },
      "additionalProperties": false
    },
    "scaling": {
      "type": "object",
      "required": ["strength", "agility", "intelligence"],
      "properties": {
        "strength": { "type": "number" },
        "agility": { "type": "number" },
        "intelligence": { "type": "number" }
      },
      "additionalProperties": false
    },
    "combatModifiers": {
      "type": "object",
      "required": ["speed", "critChance", "blockPower"],
      "properties": {
        "speed": { "type": "number" },
        "critChance": { "type": "number" },
        "blockPower": { "type": "number" }
      },
      "additionalProperties": false
    },
    "allowedClasses": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "allowedRaces": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "durability": {
      "type": "object",
      "required": ["enabled", "max"],
      "properties": {
        "enabled": { "type": "boolean" },
        "max": { "type": "number" }
      },
      "additionalProperties": false
    },
    "cost": {
      "type": "number",
      "minimum": 0
    },
    "sellValue": {
      "type": "number",
      "minimum": 0
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
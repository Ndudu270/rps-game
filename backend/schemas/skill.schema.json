{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "id",
    "name",
    "type",
    "category",
    "cost",
    "cooldown",
    "effects",
    "target",
    "range",
    "requirements",
    "description",
    "tags"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique skill identifier"
    },
    "name": {
      "type": "string",
      "description": "Display name"
    },
    "type": {
      "type": "string",
      "description": "e.g., attack, spell, buff, debuff"
    },
    "category": {
      "type": "string",
      "description": "e.g., basic, advanced, ultimate"
    },
    "cost": {
      "type": "object",
      "required": ["actionPoints", "mana", "energy", "health"],
      "properties": {
        "actionPoints": { "type": "integer", "minimum": 0 },
        "mana": { "type": "integer", "minimum": 0 },
        "energy": { "type": "integer", "minimum": 0 },
        "health": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "cooldown": {
      "type": "integer",
      "minimum": 0,
      "description": "Turns or seconds until reuse"
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "value", "scaling"],
        "properties": {
          "type": { "type": "string" },
          "value": { "type": "number" },
          "scaling": { "type": "string" }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "target": {
      "type": "string",
      "description": "enemy, ally, self, area"
    },
    "range": {
      "type": "string",
      "description": "melee, ranged, self, cone, etc."
    },
    "requirements": {
      "type": "object",
      "properties": {
        "weaponTags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "stanceIds": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
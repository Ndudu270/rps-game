{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "id",
    "name",
    "type",
    "rarity",
    "cost",
    "sellValue",
    "modifiers",
    "equipSlot",
    "stackable",
    "consumable",
    "description",
    "tags"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique item identifier"
    },
    "name": {
      "type": "string",
      "description": "Display name"
    },
    "type": {
      "type": "string",
      "description": "e.g., accessory, weapon, armor, consumable"
    },
    "rarity": {
      "type": "string",
      "description": "common, uncommon, rare, epic, legendary"
    },
    "cost": {
      "type": "integer",
      "minimum": 0,
      "description": "Purchase price"
    },
    "sellValue": {
      "type": "integer",
      "minimum": 0,
      "description": "Vendor sell price"
    },
    "modifiers": {
      "type": "object",
      "required": ["hp", "attack", "defense", "speed", "luck"],
      "properties": {
        "hp": { "type": "integer" },
        "attack": { "type": "integer" },
        "defense": { "type": "integer" },
        "speed": { "type": "integer" },
        "luck": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "equipSlot": {
      "type": "string",
      "description": "accessory, weapon, head, chest, hands, legs, feet"
    },
    "stackable": {
      "type": "boolean"
    },
    "consumable": {
      "type": "boolean"
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}